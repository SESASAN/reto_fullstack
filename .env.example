# =============================================================================
# OBSIDIAN E-commerce - Environment Variables Template
# =============================================================================
# Copiá este archivo como .env y completá con tus credenciales
# NUNCA hagás commit de .env con credenciales reales
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Configuration (obtené las credenciales de Firebase Console)
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=obsidian-xxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=obsidian-xxxxx
VITE_FIREBASE_STORAGE_BUCKET=obsidian-xxxxx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# API Configuration (FakeStore API - no necesita clave)
# -----------------------------------------------------------------------------
VITE_FAKE_STORE_API_URL=https://fakestoreapi.com
VITE_API_TIMEOUT=10000

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
VITE_APP_NAME=OBSIDIAN
VITE_APP_URL=http://localhost:5173